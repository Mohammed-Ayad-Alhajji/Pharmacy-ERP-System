<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane nodeOrientation="RIGHT_TO_LEFT" prefHeight="768.0" prefWidth="1200.0" style="-fx-background-color: #f4f6f9;" stylesheets="@/com/pharmacy/styles/global.css" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.security.UserMainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="20.0" />
            </BorderPane.margin>
            <children>
                <Label text="إدارة المستخدمين والصلاحيات 👥" textFill="#2c3e50">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleAddNewUser" styleClass="btn-primary-action" text="إضافة مستخدم جديد +">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;">
                    <children>
                        <Label text="🔍 بحث:" textFill="#34495e">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <TextField fx:id="searchField" prefWidth="250.0" promptText="الاسم، اسم المستخدم..." />
                        
                        <Region HBox.hgrow="ALWAYS" />

                        <Label text="الدور الوظيفي:" textFill="#34495e">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <ComboBox fx:id="roleFilterCombo" prefWidth="180.0" promptText="كل الأدوار" />

                        <CheckBox fx:id="showInactiveCheckBox" mnemonicParsing="false" text="عرض المستخدمين الموقوفين 🛑" textFill="#7f8c8d">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </CheckBox>
                    </children>
                </HBox>

                <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="indexCol" prefWidth="60.0" text="#" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="fullNameCol" prefWidth="250.0" text="الاسم الكامل" style="-fx-font-weight: bold;" />
                        <TableColumn fx:id="usernameCol" prefWidth="150.0" text="اسم الدخول" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="roleCol" prefWidth="150.0" text="الدور الوظيفي" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="statusCol" prefWidth="120.0" text="الحالة" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="actionCol" prefWidth="220.0" text="إجراءات" style="-fx-alignment: CENTER;" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="عرض:" textFill="#34495e"><font><Font name="System Bold" size="13.0" /></font></Label>
                        <ComboBox fx:id="rowsPerPageCombo" prefWidth="80.0" />
                        <Label text="سطراً لكل صفحة" textFill="#34495e"><font><Font name="System Bold" size="13.0" /></font></Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Pagination fx:id="pagination" maxPageIndicatorCount="5" pageCount="1" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>