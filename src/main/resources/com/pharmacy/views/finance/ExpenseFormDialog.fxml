<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox nodeOrientation="RIGHT_TO_LEFT" prefWidth="450.0" spacing="20.0" styleClass="modal-dialog" stylesheets="@/com/pharmacy/styles/global.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.finance.ExpenseFormController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <Label fx:id="formTitleLabel" text="بيانات المصروف" textFill="#2c3e50">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        
        <VBox spacing="8.0">
            <Label text="فئة المصروف *" textFill="#34495e"><font><Font name="System Bold" size="14.0" /></font></Label>
            <ComboBox fx:id="categoryCombo" editable="true" maxWidth="Infinity" prefHeight="40.0" styleClass="combo-box" />
        </VBox>
        
        <VBox spacing="8.0">
            <Label text="المبلغ *" textFill="#34495e"><font><Font name="System Bold" size="14.0" /></font></Label>
            <TextField fx:id="amountField" prefHeight="40.0" promptText="0.00" styleClass="text-field" />
        </VBox>
        
        <VBox spacing="8.0">
            <Label text="البيان / الملاحظات" textFill="#34495e"><font><Font name="System Bold" size="14.0" /></font></Label>
            <TextArea fx:id="descriptionArea" prefHeight="80.0" wrapText="true" styleClass="text-area" />
        </VBox>
        
        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="40.0" prefWidth="100.0" styleClass="button-secondary" text="إلغاء" />
                <Button fx:id="saveBtn" defaultButton="true" mnemonicParsing="false" onAction="#handleSave" prefHeight="40.0" prefWidth="150.0" styleClass="button-primary" text="حفظ" />
            </children>
        </HBox>
    </children>
</VBox>