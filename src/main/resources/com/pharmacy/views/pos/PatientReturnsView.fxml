<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" stylesheets="@/com/pharmacy/styles/global.css" nodeOrientation="RIGHT_TO_LEFT" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.pos.PatientReturnsController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="سجل مرتجعات المرضى" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="إنشاء مرتجع جديد" onAction="#handleCreateNewReturn" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 8 15; -fx-cursor: hand;" />
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #dcdde1; -fx-border-radius: 5;">
        <TextField fx:id="txtSearch" promptText="بحث (رقم الفاتورة، الزبون، الدواء...)" prefWidth="250" />
        <Separator orientation="VERTICAL" />
        <Label text="من:" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="dpStart" prefWidth="130" />
        <Label text="إلى:" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="dpEnd" prefWidth="130" />
        <Button text="بحث وتطبيق" onAction="#handleSearch" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;" prefWidth="100" />
        <Button text="تحديث وإلغاء الفلاتر" onAction="#loadInitialData" style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50; -fx-border-color: #bdc3c7;" prefWidth="140" />
    </HBox>

    <VBox spacing="5" VBox.vgrow="ALWAYS">
        <TableView fx:id="tvReturns" VBox.vgrow="ALWAYS" styleClass="main-table">
            <columns>
                <TableColumn fx:id="colIndex" text="#" prefWidth="40" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colSaleId" text="الفاتورة" prefWidth="90" style="-fx-alignment: CENTER; -fx-font-weight: bold;" />
                <TableColumn fx:id="colCustomer" text="الزبون" prefWidth="150" />
                <TableColumn fx:id="colMedicineBatch" text="الدواء والطبخة" prefWidth="250" style="-fx-text-fill: #2980b9; -fx-font-weight: bold;" />
                <TableColumn fx:id="colQtyReturned" text="الكمية المرتجعة" prefWidth="110" style="-fx-alignment: CENTER; -fx-text-fill: #e74c3c; -fx-font-weight: bold;" />
                <TableColumn fx:id="colRefundAmount" text="الاسترداد النقدي" prefWidth="120" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;" />
                <TableColumn fx:id="colReturnDate" text="تاريخ المرتجع" prefWidth="140" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colPharmacist" text="الصيدلي المسؤول" prefWidth="120" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colReason" text="السبب" prefWidth="150" />
            </columns>
            <placeholder>
                <Label text="لا توجد حركات إرجاع مطابقة للفلاتر الحالية" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
            </placeholder>
        </TableView>
    </VBox>

    <HBox alignment="CENTER" spacing="15" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-border-color: #dcdde1; -fx-border-radius: 4; -fx-background-radius: 4;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="عرض:" />
            <ComboBox fx:id="cbRowsPerPage" prefWidth="80" />
            <Label text="سطر" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER_RIGHT" spacing="15">
            <Button fx:id="btnNext" text="التالي" onAction="#handleNextPage" style="-fx-cursor: hand;" />
            <Label fx:id="lblPageInfo" text="صفحة 1 من 1" style="-fx-font-weight: bold;" />
            <Button fx:id="btnPrev" text="السابق" onAction="#handlePrevPage" style="-fx-cursor: hand;" />
        </HBox>
    </HBox>

</VBox>