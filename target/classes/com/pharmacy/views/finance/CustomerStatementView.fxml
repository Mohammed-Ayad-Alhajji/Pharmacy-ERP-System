<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" stylesheets="@/com/pharmacy/styles/global.css" prefWidth="1050" prefHeight="700" 
      nodeOrientation="RIGHT_TO_LEFT" xmlns="http://javafx.com/javafx/17" 
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.finance.CustomerStatementController">
    <padding>
        <Insets top="20" right="25" bottom="20" left="25"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="كشف حساب عميل محلي (تفصيلي)" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="طباعة وتصدير PDF" onAction="#handleExportPDF" styleClass="btn-primary" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand;" />
        <Button text="تصدير Excel" onAction="#handleExportExcel" styleClass="btn-primary" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand;" />
    </HBox>

    <Separator />

    <GridPane hgap="20" vgap="15" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-radius: 8;">
        <columnConstraints>
            <ColumnConstraints minWidth="80" />
            <ColumnConstraints minWidth="250" />
            <ColumnConstraints minWidth="80" />
            <ColumnConstraints minWidth="150" />
            <ColumnConstraints minWidth="80" />
            <ColumnConstraints minWidth="150" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <Label text="ابحث عن العميل:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="cbCustomer" promptText="اكتب اسم العميل..." editable="true" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="من تاريخ:" style="-fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <DatePicker fx:id="dpStartDate" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <Label text="إلى تاريخ:" style="-fx-font-weight: bold;" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
        <DatePicker fx:id="dpEndDate" maxWidth="Infinity" GridPane.columnIndex="5" GridPane.rowIndex="0"/>

        <HBox spacing="10" alignment="CENTER_RIGHT" GridPane.columnIndex="6" GridPane.rowIndex="0">
            <Button text="توليد كشف الحساب" onAction="#handleGenerateStatement" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;" />
        </HBox>
    </GridPane>

    <HBox spacing="20" alignment="CENTER">
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #bdc3c7; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
            <Label text="الرصيد الافتتاحي (ديون سابقة)" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold;" />
            <Label fx:id="lblInitialBalance" text="0 ل.س" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />
        </VBox>
        
        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #fdedec; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #f5b7b1; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
            <Label text="المدين (فواتير على العميل)" style="-fx-text-fill: #c0392b; -fx-font-weight: bold;" />
            <Label fx:id="lblTotalDebit" text="0 ل.س" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #c0392b;" />
        </VBox>

        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #e8f8f5; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #a3e4d7; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
            <Label text="الدائن (دفعات استلمناها منه)" style="-fx-text-fill: #117a65; -fx-font-weight: bold;" />
            <Label fx:id="lblTotalCredit" text="0 ل.س" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #16a085;" />
        </VBox>

        <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #fef9e7; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #f1c40f; -fx-border-radius: 10; -fx-border-width: 2;" HBox.hgrow="ALWAYS">
            <Label text="إجمالي الذمة المستحقة" style="-fx-text-fill: #d35400; -fx-font-weight: bold; -fx-font-size: 14px;" />
            <Label fx:id="lblFinalBalance" text="0 ل.س" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" />
        </VBox>
    </HBox>

    <TableView fx:id="tvStatement" VBox.vgrow="ALWAYS" styleClass="main-table">
        <columns>
            <TableColumn fx:id="colIndex" text="#" prefWidth="40" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colDate" text="التاريخ والوقت" prefWidth="150" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colType" text="نوع الحركة" prefWidth="160" style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
            <TableColumn fx:id="colRef" text="رقم المستند" prefWidth="120" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colDetails" text="البيان (التفاصيل)" prefWidth="250" />
            
            <TableColumn fx:id="colDebit" text="مدين (على العميل)" prefWidth="130" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
            <TableColumn fx:id="colCredit" text="دائن (دفعة لنا)" prefWidth="130" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
            
            <TableColumn fx:id="colBalance" text="الرصيد التراكمي" prefWidth="150" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-color: #fdf2e9;"/>
        </columns>
        <placeholder>
            <Label text="يرجى تحديد العميل والفترة ثم الضغط على 'توليد كشف الحساب'" style="-fx-font-size: 15px; -fx-text-fill: #95a5a6;"/>
        </placeholder>
    </TableView>

</VBox>