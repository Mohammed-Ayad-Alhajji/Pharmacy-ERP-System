<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane nodeOrientation="RIGHT_TO_LEFT" prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f6f9;" stylesheets="@/com/pharmacy/styles/global.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.inventory.MedicineCategoryController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" BorderPane.alignment="CENTER">
            <children>
                <Label text="دليل التصنيفات الدوائية" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="searchField" prefWidth="250.0" promptText="بحث في التصنيفات..." styleClass="search-field" />
                <Button mnemonicParsing="false" onAction="#handleAddNewCategory" styleClass="button-primary" text="إضافة صنف جديد +">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            </children>
            <BorderPane.margin>
                <Insets bottom="20.0" />
            </BorderPane.margin>
        </HBox>
    </top>
    <center>
        <VBox spacing="10.0" styleClass="table-container" BorderPane.alignment="CENTER">
            <children>
                <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idCol" prefWidth="100.0" text="الرقم" />
                        <TableColumn fx:id="nameCol" prefWidth="300.0" text="اسم الصنف" />
                        <TableColumn fx:id="descCol" prefWidth="400.0" text="الوصف / الملاحظات" />
                        <TableColumn fx:id="actionCol" prefWidth="180.0" text="إجراءات" />
                    </columns>
                </TableView>
                
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="عرض:" textFill="#34495e">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Label>
                        <ComboBox fx:id="rowsPerPageCombo" prefWidth="80.0" />
                        <Label text="سطراً لكل صفحة" textFill="#34495e">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Pagination fx:id="pagination" maxPageIndicatorCount="5" pageCount="1" />
                    </children>
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </HBox>

            </children>
        </VBox>
    </center>
</BorderPane>
