<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox fx:id="navbar" alignment="CENTER_LEFT" nodeOrientation="RIGHT_TO_LEFT" prefHeight="70.0" spacing="15.0" styleClass="navbar" stylesheets="@/com/pharmacy/styles/global.css" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controllers.components.NavbarController">
    <padding>
        <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
    </padding>
    <children>
        
        <Button fx:id="toggleSidebarButton" mnemonicParsing="false" onAction="#handleToggleSidebar" styleClass="navbar-icon-btn" text="☰" />
        
        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button fx:id="shiftStatusButton" mnemonicParsing="false" onAction="#handleShiftAction" styleClass="shift-closed-btn" text="إدارة الوردية 🔴" />
                <Button fx:id="quickSaleButton" mnemonicParsing="false" onAction="#handleQuickSale" styleClass="btn-primary-action" text="نقطة البيع 🛒" />
                
                <MenuButton fx:id="receiptVoucherMenu" mnemonicParsing="false" 
                            minHeight="40.0" prefHeight="40.0" maxHeight="40.0" 
                            minWidth="133.0" prefWidth="115.0" maxWidth="115.0" 
                            styleClass="custom-menu-btn" text="سند قبض 📥">
                    <items>
                        <MenuItem fx:id="customerPaymentItem" mnemonicParsing="false" onAction="#handleCustomerPayment" style="-fx-pref-width: 120.0;" text="من عميل (ذمم)" />
                        <MenuItem fx:id="insurancePaymentItem" mnemonicParsing="false" onAction="#handleInsurancePayment" style="-fx-pref-width: 120.0;" text="من شركة تأمين" />
                    </items>
                </MenuButton>
                
                <Button fx:id="supplierPaymentButton" mnemonicParsing="false" onAction="#handleSupplierPayment" 
                        minHeight="40.0" prefHeight="40.0" maxHeight="40.0" 
                        minWidth="125.0" prefWidth="115.0" maxWidth="115.0" 
                        styleClass="custom-menu-btn" text="سند صرف 📤" />
            </children>
            <HBox.margin>
                <Insets left="20.0" />
            </HBox.margin>
        </HBox>
        
        <Region HBox.hgrow="ALWAYS" />
        
        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <StackPane>
                    <children>
                        <Button fx:id="lowStockAlertsButton" mnemonicParsing="false" onAction="#handleLowStockAlerts" styleClass="alert-danger-btn" text="نواقص 📉" />
                        <Label fx:id="lowStockBadge" alignment="CENTER" styleClass="badge-label, badge-danger" text="89" StackPane.alignment="TOP_LEFT" />
                    </children>
                </StackPane>

                <StackPane>
                    <children>
                        <Button fx:id="expiryAlertsButton" mnemonicParsing="false" onAction="#handleExpiryAlerts" styleClass="alert-warning-btn" text="صلاحية ⏱️" />
                        <Label fx:id="expiryBadge" alignment="CENTER" styleClass="badge-label, badge-warning" text="1" StackPane.alignment="TOP_LEFT" />
                    </children>
                </StackPane>
            </children>
        </HBox>

        <Region prefWidth="1.0" style="-fx-background-color: #ecf0f1;" />

        <VBox alignment="CENTER_LEFT" spacing="2.0">
            <children>
                <Label fx:id="navUserNameLabel" text="المدير العام" textFill="#2c3e50">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Label>
                <Label fx:id="navUserRoleLabel" text="مدير النظام" textFill="#7f8c8d">
                    <font><Font size="12.0" /></font>
                </Label>
            </children>
            <HBox.margin>
                <Insets left="15.0" />
            </HBox.margin>
        </VBox>

    </children>
</HBox>